{
  "name": "archguard",
  "version": "1.0.0",
  "description": "Architectural guardrail system for IBM Bob using Granite-3-8b",
  "main": "dist/mcp/index.js",
  "bin": {
    "archguard": "dist/cli.js"
  },
  "files": [
    "dist/",
    "templates/",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "start": "node dist/mcp/index.js",
    "dev": "ts-node src/mcp/index.ts",
    "dashboard": "ts-node src/dashboard/server.ts",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "mcp",
    "ibm-bob",
    "archguard",
    "watsonx",
    "architectural-guardrails",
    "code-validation",
    "ai-safety",
    "granite",
    "model-context-protocol"
  ],
  "author": "Bernard Blay",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/yourusername/archguard.git"
  },
  "bugs": {
    "url": "https://github.com/yourusername/archguard/issues"
  },
  "homepage": "https://github.com/yourusername/archguard#readme",
  "engines": {
    "node": ">=16.0.0"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "cors": "^2.8.5",
    "dotenv": "^17.4.2",
    "express": "^4.18.2"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^20.0.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.0.0"
  }
}
